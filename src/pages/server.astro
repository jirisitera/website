---
import Base from "../components/Base.astro";
---

<html lang="en">
  <Base
    title="Minecraft Server Status | JapiWeb"
    description="Check if a Minecraft server is online and view basic information like version and player count."
    color="#6b1f35"
  />
  <body
    class="relative inset-0 z-0 min-h-screen overflow-x-hidden"
    style={{
      background: `
        linear-gradient(150deg, #17070d 0%, #2b0b18 42%, #3a1223 100%),
        radial-gradient(circle at 16% 18%, rgba(255, 140, 172, 0.2) 0%, transparent 40%),
        radial-gradient(circle at 84% 78%, rgba(255, 112, 151, 0.12) 0%, transparent 40%)
      `,
      backgroundSize: "100% 100%, 100% 100%, 100% 100%",
      backgroundAttachment: "fixed",
    }}
  >
    <div class="pointer-events-none fixed inset-0">
      <div class="ambient-float absolute top-0 left-1/5 h-96 w-96 rounded-full bg-rose-300/10 blur-3xl" style={{ animationDuration: "9s" }}>
      </div>
      <div
        class="ambient-float absolute right-1/4 bottom-0 h-96 w-96 rounded-full bg-red-400/10 blur-3xl"
        style={{ animationDuration: "12s", animationDelay: "1s" }}
      >
      </div>
    </div>
    <main class="relative z-10 mx-auto w-full max-w-3xl px-6 py-12">
      <section class="section-shell section-tools mb-8">
        <div class="mb-4 flex items-start justify-between gap-3">
          <div class="section-kicker mb-0">GAME TOOL</div>
          <a
            href="/"
            class="touch-target rounded-full border border-white/14 bg-black/15 px-4 py-2 text-xs font-semibold tracking-wide text-rose-50/95 transition hover:border-rose-300/50"
          >
            Back to Home
          </a>
        </div>
        <h1 class="section-title mb-2 text-center text-3xl font-semibold lg:text-4xl">Minecraft Server Status</h1>
        <p class="section-subtitle mx-auto max-w-2xl text-center text-sm lg:text-base">Enter a Java server address and check its status.</p>
        <div class="accent-line mx-auto mt-5 mb-6"></div>
        <div class="glass rounded-2xl p-5">
          <label for="serverInput" class="mb-2 block text-sm font-semibold text-rose-50">Server Address</label>
          <div class="flex flex-col gap-3 lg:flex-row">
            <input
              id="serverInput"
              type="text"
              placeholder="play.hypixel.net"
              class="touch-target w-full rounded-full border border-white/15 bg-white/8 px-4 py-2 text-sm text-rose-50 transition outline-none placeholder:text-rose-100/40 focus:border-rose-300/60"
              autocomplete="off"
            />
            <button
              id="checkBtn"
              type="button"
              class="touch-target rounded-full border border-white/20 bg-white/8 px-4 py-2 text-sm font-semibold tracking-wide whitespace-nowrap text-rose-50 transition hover:border-rose-300/60 hover:bg-rose-300/10"
            >
              Check Status
            </button>
          </div>
          <p class="mt-3 text-xs text-rose-100/70">Supports hostnames and IP addresses, optionally with a port.</p>
        </div>
      </section>
      <section class="section-shell section-tools">
        <h2 class="section-title mb-3 text-center text-xl font-semibold">Server Info</h2>
        <div id="statusBanner" class="glass-sm mb-4 rounded-2xl p-4 text-center text-sm text-rose-100/85" aria-live="polite">
          Enter a server address and click Check Status.
        </div>
        <div id="resultGrid" class="grid gap-3 sm:grid-cols-2">
          <div class="glass-sm rounded-2xl p-4">
            <div class="mb-1 text-xs tracking-[0.16em] text-rose-100/70 uppercase">Host</div>
            <output id="hostValue" class="block text-sm text-rose-50">-</output>
          </div>
          <div class="glass-sm rounded-2xl p-4">
            <div class="mb-1 text-xs tracking-[0.16em] text-rose-100/70 uppercase">Status</div>
            <output id="onlineValue" class="block text-sm font-semibold text-rose-50">Unknown</output>
          </div>
          <div class="glass-sm rounded-2xl p-4">
            <div class="mb-1 text-xs tracking-[0.16em] text-rose-100/70 uppercase">Version</div>
            <output id="versionValue" class="block text-sm text-rose-50">-</output>
          </div>
          <div class="glass-sm rounded-2xl p-4">
            <div class="mb-1 text-xs tracking-[0.16em] text-rose-100/70 uppercase">Players</div>
            <output id="playersValue" class="block text-sm text-rose-50">-</output>
          </div>
          <div class="glass-sm rounded-2xl p-4 sm:col-span-2">
            <div class="mb-1 text-xs tracking-[0.16em] text-rose-100/70 uppercase">MOTD</div>
            <output id="motdValue" class="block text-sm text-rose-50">-</output>
          </div>
        </div>
      </section>
    </main>
    <script>
      type McApiResponse = {
        online?: boolean;
        hostname?: string;
        ip?: string;
        port?: number;
        version?: string;
        players?: {
          online?: number;
          max?: number;
        };
        motd?: {
          clean?: string[];
        };
      };
      const serverInput = document.querySelector<HTMLInputElement>("#serverInput");
      const checkBtn = document.querySelector<HTMLButtonElement>("#checkBtn");
      const statusBanner = document.querySelector<HTMLElement>("#statusBanner");
      const hostValue = document.querySelector<HTMLOutputElement>("#hostValue");
      const onlineValue = document.querySelector<HTMLOutputElement>("#onlineValue");
      const versionValue = document.querySelector<HTMLOutputElement>("#versionValue");
      const playersValue = document.querySelector<HTMLOutputElement>("#playersValue");
      const motdValue = document.querySelector<HTMLOutputElement>("#motdValue");
      function setBanner(message: string, isError = false): void {
        if (!statusBanner) {
          return;
        }
        statusBanner.textContent = message;
        statusBanner.classList.toggle("text-rose-200", isError);
        statusBanner.classList.toggle("text-rose-100/85", !isError);
      }
      function setOutput(target: HTMLOutputElement | null, value: string): void {
        if (!target) {
          return;
        }
        target.textContent = value;
      }
      function clearOutputs(): void {
        setOutput(hostValue, "-");
        setOutput(onlineValue, "Unknown");
        setOutput(versionValue, "-");
        setOutput(playersValue, "-");
        setOutput(motdValue, "-");
      }
      async function checkServer(): Promise<void> {
        const address = serverInput?.value.trim();
        if (!address) {
          setBanner("Enter a server address first.", true);
          clearOutputs();
          return;
        }
        setBanner("Checking server status...");
        checkBtn?.setAttribute("disabled", "true");
        try {
          const response = await fetch(`https://api.mcsrvstat.us/3/${encodeURIComponent(address)}`, {
            cache: "no-store",
          });

          if (!response.ok) {
            throw new Error(`Status API returned ${response.status}`);
          }
          const data = (await response.json()) as McApiResponse;
          const host = [data.hostname ?? data.ip ?? address, data.port].filter(Boolean).join(":");
          const isOnline = Boolean(data.online);
          const version = data.version?.trim() || "Unknown";
          const playerOnline = data.players?.online;
          const playerMax = data.players?.max;
          const playerText =
            typeof playerOnline === "number" && typeof playerMax === "number" ? `${playerOnline} / ${playerMax}` : "Unknown";
          const motd = data.motd?.clean?.filter(Boolean).join(" ").trim() || "No MOTD available";
          setOutput(hostValue, host || address);
          setOutput(onlineValue, isOnline ? "Online" : "Offline");
          setOutput(versionValue, version);
          setOutput(playersValue, playerText);
          setOutput(motdValue, motd);
          if (isOnline) {
            setBanner("Server is online.");
          } else {
            setBanner("Server appears to be offline or unreachable.", true);
          }
        } catch {
          setBanner("Could not fetch server status. Please try again in a moment.", true);
          clearOutputs();
        } finally {
          checkBtn?.removeAttribute("disabled");
        }
      }
      checkBtn?.addEventListener("click", () => {
        void checkServer();
      });
      serverInput?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          void checkServer();
        }
      });
    </script>
  </body>
</html>
