---
import Base from "../components/Base.astro";
---

<html lang="en">
  <Base />
  <body
    class="relative inset-0 z-0 min-h-screen overflow-x-hidden"
    style={{
      background: `
        linear-gradient(150deg, #0a0d13 0%, #101724 42%, #132133 100%),
        radial-gradient(circle at 14% 20%, rgba(66, 153, 225, 0.2) 0%, transparent 38%),
        radial-gradient(circle at 82% 80%, rgba(76, 194, 255, 0.15) 0%, transparent 40%)
      `,
      backgroundSize: "100% 100%, 100% 100%, 100% 100%",
      backgroundAttachment: "fixed",
    }}
  >
    <div class="pointer-events-none fixed inset-0 opacity-25" aria-hidden="true">
      <div class="ambient-float absolute top-8 left-1/4 h-72 w-72 rounded-full bg-sky-400/10 blur-3xl" style={{ animationDuration: "10s" }}>
      </div>
      <div
        class="ambient-float absolute right-1/4 bottom-8 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"
        style={{ animationDuration: "12s", animationDelay: "1s" }}
      >
      </div>
    </div>

    <main class="relative z-10 mx-auto flex min-h-screen w-full max-w-3xl items-center px-6 py-12">
      <section class="section-shell section-note w-full text-center">
        <p class="section-kicker">Error 404</p>
        <h1 class="section-title mb-3 text-4xl font-semibold lg:text-5xl">This page drifted off course</h1>
        <p class="section-subtitle mx-auto mb-8 max-w-xl text-sm lg:text-base">
          The page you are looking for does not exist, was moved, or the URL is incorrect.
        </p>
        <div class="mx-auto mb-8 h-px w-full max-w-sm bg-linear-to-r from-transparent via-white/35 to-transparent"></div>
        <a
          href="/"
          class="touch-target inline-flex items-center justify-center rounded-full border border-sky-300/45 bg-sky-400/12 px-5 py-2.5 text-sm font-medium text-sky-100 transition hover:border-sky-300/75 hover:bg-sky-400/20"
        >
          Back to homepage
        </a>
      </section>
    </main>
  </body>
</html>
