---
const { name, experience, details } = Astro.props;
---

<article class="skill-card glass glass-hover mb-1 rounded-2xl">
  <div class="skill-card__group">
    <div class="lg:col-span-4">
      <div class="mb-1 text-[0.65rem] font-semibold tracking-[0.12em] text-slate-300/90 uppercase">Skill</div>
      <div class="text-lg font-semibold text-slate-100">{name}</div>
    </div>
    <div class="lg:col-span-3">
      <div class="mb-1 text-[0.65rem] font-semibold tracking-[0.12em] text-slate-300/90 uppercase">Experience</div>
      <span class="inline-flex rounded-full border border-sky-300/35 bg-sky-400/12 px-2.5 py-1 text-xs font-medium text-sky-100">
        {experience}
      </span>
    </div>
    <div class="lg:col-span-5">
      <div class="mb-1 text-[0.65rem] font-semibold tracking-[0.12em] text-slate-300/90 uppercase">Details</div>
      <p class="text-sm leading-relaxed text-slate-200">{details}</p>
    </div>
  </div>
</article>
