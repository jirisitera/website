---
const { icon, label, contact, href, target = "", rel = "noreferrer nofollow" } = Astro.props;
---

<div class="glass glass-hover group relative rounded-2xl border border-white/14 p-4 transition lg:p-6">
  <a class="absolute inset-0 z-10 rounded-2xl" {href} rel={rel} {target} aria-label={`Open ${label}`}> </a>
  <div class="pointer-events-none relative z-20 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
    <div class="flex min-w-0 items-center gap-3">
      <span class="shrink-0 rounded-full border border-sky-300/40 bg-sky-400/10 px-2 py-1 text-xs text-sky-200">{icon}</span>
      <div class="min-w-0">
        <div class="text-lg font-semibold text-slate-100 group-hover:text-sky-100">{label}</div>
        <p class="text-sm text-slate-300 transition group-hover:text-slate-100">{contact}</p>
      </div>
    </div>
    <button
      type="button"
      class="copy-button touch-target pointer-events-auto shrink-0 rounded-full border border-white/15 bg-white/8 px-3 py-1.5 text-xs font-medium text-slate-100 transition hover:border-sky-300/50 hover:bg-sky-400/10"
      data-copy-target={contact}
      aria-label={`Copy ${label.toLowerCase()} to clipboard`}
    >
      Copy
    </button>
  </div>
</div>
