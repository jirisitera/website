---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
import Skill from "./Skill.astro";
import Project from "./Project.astro";
import Tool from "./Tool.astro";
import Contact from "./Contact.astro";
import skills from "../data/skills.json";
import projects from "../data/projects.json";
import tools from "../data/tools.json";
import contacts from "../data/contacts.json";
---

<section class="mx-auto mt-10 mb-16 w-full max-w-none px-6 transition lg:max-w-5xl">
  <div class="section-shell section-hero mb-12">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-start">
      <div>
        <div class="section-kicker">JAPICRAFT.COM</div>
        <div class="section-title mb-2 text-center text-3xl font-semibold lg:text-left lg:text-4xl">Always building something new.</div>
        <p class="section-subtitle mx-auto mb-0 max-w-xl text-center text-sm lg:mx-0 lg:text-left lg:text-base">
          Hi! I'm Japi, a developer and system engineer from the Czech Republic.
        </p>
      </div>
      <Image
        src={logo}
        alt="Logo"
        class="mx-auto h-20 w-20 rounded-full shadow-lg ring-1 ring-white/30 lg:mx-0 lg:h-24 lg:w-24 lg:justify-self-end"
        loading="eager"
      />
    </div>
  </div>
  <div class="section-shell section-projects mb-12">
    <div class="section-kicker">MY WORK</div>
    <h2 class="section-title mb-2 text-center text-3xl font-semibold lg:text-4xl">Projects</h2>
    <p class="section-subtitle mx-auto mb-5 max-w-2xl text-center text-sm">Cool projects I made during long, sleepless nights.</p>
    <div class="accent-line mx-auto mb-8"></div>
    <div class="grid gap-4">
      {
        projects.map((item: { url: string; name: string; description: string }) => (
          <Project url={item.url} name={item.name} description={item.description} />
        ))
      }
    </div>
  </div>
  <div class="section-shell section-skills mb-12">
    <div class="section-kicker">SKILLBOOK</div>
    <h2 class="section-title mb-2 text-center text-3xl font-semibold lg:text-4xl">Skills</h2>
    <p class="section-subtitle mx-auto mb-5 max-w-2xl text-center text-sm">Some of the stuff I learned over the years.</p>
    <div class="accent-line mx-auto mb-8"></div>
    <div class="grid gap-4">
      {skills.map((item: { name: string; experience: string; details: string }) => <Skill {...item} />)}
    </div>
  </div>
  <div class="section-shell section-tools mb-12">
    <div class="section-kicker">TOOLBOX</div>
    <h2 class="section-title mb-2 text-center text-3xl font-semibold lg:text-4xl">Tools</h2>
    <p class="section-subtitle mx-auto mb-5 max-w-2xl text-center text-sm">A few of my tools available right on this site.</p>
    <div class="accent-line mx-auto mb-8"></div>
    <div class="grid gap-4">
      {
        tools.map((item: { href: string; name: string; description: string }) => (
          <Tool href={item.href} name={item.name} description={item.description} />
        ))
      }
    </div>
  </div>
  <div class="section-shell section-contact mb-12">
    <div class="section-kicker">REACH OUT</div>
    <h2 class="section-title mb-2 text-center text-3xl font-semibold lg:text-4xl">Contact</h2>
    <p class="section-subtitle mx-auto mb-5 max-w-2xl text-center text-sm">Feel free to reach out, I'm always open to new things.</p>
    <div class="accent-line mx-auto mb-8"></div>
    <div class="grid gap-4">
      {
        contacts.map((item: { icon: string; label: string; contact: string; href: string; target: string; rel: string }) => (
          <Contact icon={item.icon} label={item.label} contact={item.contact} href={item.href} target={item.target} rel={item.rel} />
        ))
      }
    </div>
  </div>
  <div class="section-shell section-note text-center text-slate-300">
    Thanks for checking out my website! In case you need inspiration, this site is fully open sourced on my GitHub.
  </div>
</section>
<script>
  const buttons = document.querySelectorAll("[data-copy-target]");
  buttons.forEach((button) => {
    button.addEventListener("click", async (event) => {
      event.preventDefault();
      event.stopPropagation();
      const target = button.getAttribute("data-copy-target");
      if (!target) {
        return;
      }
      try {
        await navigator.clipboard.writeText(target);
      } catch {
        button.textContent = "Unavailable";
        window.setTimeout(() => {
          button.textContent = "Copy";
        }, 1400);
        return;
      }
      const previousLabel = button.textContent;
      button.textContent = "Copied";
      button.setAttribute("aria-label", "Copied to clipboard");
      window.setTimeout(() => {
        button.textContent = previousLabel;
        button.setAttribute("aria-label", "Copy to clipboard");
      }, 1400);
    });
  });
</script>
