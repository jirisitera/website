---
const { href, name, description } = Astro.props;
---

<a {href} class="tool-card group rounded-2xl p-4 lg:p-6">
  <div class="flex items-start justify-between gap-4 lg:items-center">
    <div>
      <h3 class="text-lg font-semibold text-rose-50 group-hover:text-rose-100">{name}</h3>
      <p class="mt-1 text-sm text-rose-100/80">{description}</p>
    </div>
    <span class="rounded-full border border-rose-300/45 bg-rose-300/12 px-2 py-1 text-xs text-rose-100">→</span>
  </div>
</a>
