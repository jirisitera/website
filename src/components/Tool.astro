---
const { href, name, description } = Astro.props;
---

<a {href} class="glass glass-hover group rounded-2xl border border-white/14 p-4 transition lg:p-6">
  <div class="flex items-start justify-between gap-4 lg:items-center">
    <div>
      <h3 class="text-lg font-semibold text-slate-100 group-hover:text-sky-100">{name}</h3>
      <p class="mt-1 text-sm text-slate-300">{description}</p>
    </div>
    <span class="rounded-full border border-sky-300/40 bg-sky-400/10 px-2 py-1 text-xs text-sky-200">→</span>
  </div>
</a>
